# Dependencies — always reinstalled inside the container
**/node_modules

# Previous build output — rebuilt inside the container
# Excluding this also prevents stale artifacts from busting the layer cache
.next

# Local and dev env files — production build only needs .env.production
.env.local
.env.development
.env.development.local
.env.test.local
.env.production.local

# Docker files themselves (no need to copy into the build context)
Dockerfile*
.dockerignore

# Version control
.git
.gitignore

# Dev tooling — not needed at build or runtime
*.log
npm-debug.log*
.DS_Store
*.md

# Tests
**/*.test.*
**/*.spec.*
coverage
